# Predict Pro — root environment for Docker Compose
# Copy to `.env` (the start scripts do this automatically) and edit as needed.
# Every value has a safe default, so the stack runs out of the box.

# ---- Ports (change only if these are already in use on your machine) ----
BACKEND_PORT=3001
ADMIN_PORT=3000
POSTGRES_PORT=5432

# ---- Runtime mode ----
# development = admin password always synced from ADMIN_PASSWORD below (easiest)
# production  = admin seeded once on first run; CORS locked to CORS_ORIGINS
NODE_ENV=development

# ---- Database (used inside Docker) ----
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=predict_pro

# ---- Admin login (used to sign into the dashboard) ----
ADMIN_EMAIL=admin@predictpro.local
ADMIN_PASSWORD=admin123

# ---- Security (CHANGE FOR PRODUCTION) ----
JWT_SECRET=change-me-use-a-long-random-string

# ---- CORS (browser origins allowed to call the backend) ----
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ---- Admin build: URL the browser uses to reach the backend ----
NEXT_PUBLIC_API_URL=http://localhost:3001

# ---- Live data (optional) ----
# Leave API_FOOTBALL_KEY blank to run in demo mode (simulated live scores/odds).
LIVE_DEMO_MODE=true
LIVE_POLL_INTERVAL_MS=30000
API_FOOTBALL_KEY=

# ---- Push notifications (optional) ----
# Without Firebase credentials, pushes run in mock mode (logged only).
FCM_ENABLED=false
