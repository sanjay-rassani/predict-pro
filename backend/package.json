{
  "name": "predict-pro-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Predict Pro API — Express, PostgreSQL, Socket.IO",
  "type": "module",
  "scripts": {
    "dev": "node --watch src/index.js",
    "start": "node src/index.js",
    "migrate": "node scripts/migrate.js up",
    "migrate:down": "node scripts/migrate.js down",
    "seed": "node scripts/seed.js",
    "test": "node --test --test-concurrency=1 test/**/*.test.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "prettier": "^3.9.4",
    "socket.io-client": "^4.8.3",
    "supertest": "^7.2.2"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "firebase-admin": "^14.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.11.0",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.22.0",
    "socket.io": "^4.8.3"
  }
}
