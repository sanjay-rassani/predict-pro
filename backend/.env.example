# Server
PORT=3001
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/predict_pro

# Auth (single admin — seeded in Section 1)
JWT_SECRET=change-me-use-openssl-rand-hex-32
ADMIN_EMAIL=admin@predictpro.local
ADMIN_PASSWORD=admin123

# API-Football (https://www.api-football.com/)
API_FOOTBALL_KEY=
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io

# Firebase Cloud Messaging (Section 4)
# Path to service account JSON, or inline JSON string
FCM_SERVICE_ACCOUNT_PATH=
FCM_ENABLED=false

# CORS — comma-separated origins (admin + mobile dev)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Live scores poller (Section 2)
LIVE_POLL_INTERVAL_MS=30000
# Set true to simulate live updates without API-Football key
LIVE_DEMO_MODE=true
